{
  "customColumns": [
    {
      "name": "outil",
      "index": 0,
      "showChart": true,
      "showQuickFilter": true,
      "showFilter": true
    },
    {
      "name": "package",
      "index": 1,
      "showChart": true,
      "showQuickFilter": true,
      "showFilter": true,
      "fromField": "location.path",
      "fieldRegex": "src/([^/]+)/.*"
    }
  ],
  "reportPatterns": [
    {
      "glob": "reports/*.json",
      "regex": "(\\w+)-.*\\.json",
      "values": {
        "outil": "$0"
      }
    }
  ]
}
