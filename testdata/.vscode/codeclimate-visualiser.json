{
  "customColumns": [
    {
      "name": "outil",
      "index": 3,
      "showChart": true,
      "showFilter": true
    },
    {
      "name": "sous-système",
      "index": 4,
      "showChart": true,
      "showFilter": true,
      "fromField": "location.path",
      "fieldRegex": ".*/sous-systemes/(\\w+)/.*"
    }
  ],
  "reportPatterns": [
    {
      "glob": "reports/*-*.json",
      "regex": "(\\w+)-(\\w+)\\.json",
      "values": {
        "outil": "$0"
      }
    }
  ]
}
